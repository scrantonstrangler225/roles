---
# Human users
users_human:
  - name: vagrant
    groups:
      - sudo
      - docker
    ssh_keys:
      - "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIGzWeKX3L6SMTSSYQNIfzedeEN+JiT18Sq79Du2WMDXD vagrant@minion2"
        #- "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIHDMC+m53Gr99ZURzUOkyHLqTOK65RNmHS7S031Cw1mZ vagrant"

# Service users
users_service:
  - name: docker
    group: docker
  - name: nginx
    group: www-data
  - name: concourse_ci_user
    group: concourse
  - name: wazuh
    group: wazuh
  - name: gitbot
    group: git
  - name: backup
    group: backup
